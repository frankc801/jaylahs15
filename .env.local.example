# ----------------------------------------------------------------------------
# Jaylah XV Digital Invitation — Environment Variables
# Copy this file to `.env.local` and fill in the values.
# ----------------------------------------------------------------------------

# Supabase — public (safe to expose to the browser).
# Used by the public RSVP form to insert submissions.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase — service role (SERVER ONLY — never prefix with NEXT_PUBLIC).
# Used by the admin dashboard and check-in page to read/update RSVPs.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Admin dashboard / check-in access (SERVER ONLY).
# ADMIN_PASSWORD protects /admin and /check-in.
# SESSION_SECRET is any long random string used to sign the session cookie.
ADMIN_PASSWORD=change-me-to-a-strong-password
SESSION_SECRET=change-me-to-a-long-random-string
